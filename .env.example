# GainAlgo - environment. Copy this to .env and fill in.
# Defaults are SAFE (dry/paper, single server). Go live only after testing.

AUTOBOT_LIVE=0            # 0 = dry/paper (default, safe) / 1 = live
DASHBOARD_PASSWORD=change_me

# Exchange API keys (fill ONLY what you use; withdrawal permission OFF)
BYBIT_API_KEY=
BYBIT_API_SECRET=
UPBIT_API_KEY=
UPBIT_API_SECRET=
BITHUMB_API_KEY=
BITHUMB_API_SECRET=

# Single server (default). Multi-server "fleet" is ADVANCED/optional.
PEER_SERVER_URLS=
# PEER_BRIEF_TOKEN=
# CF_ACCESS_CLIENT_ID=
# CF_ACCESS_CLIENT_SECRET=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
