# GainAlgo - environment. Copy this to .env and fill in.
# Defaults are SAFE (dry/paper, single server). Go live only after testing.

TRADING_MODE=PAPER       # PAPER = all engines simulated (default, safe) / LIVE = real orders (only after testing)
AUTOBOT_LIVE=0           # extra live gate for Bybit USDT-M futures (live needs TRADING_MODE=LIVE AND this=1)
PAPER_SLIPPAGE_BPS=5     # paper fill slippage per side (bps). Makes paper PnL ~ live. 10-20 realistic for thin alts. DON'T trust paper profit without this.
DASHBOARD_PASSWORD=change_me

# Exchange API keys (fill ONLY what you use; withdrawal permission OFF)
BYBIT_API_KEY=
BYBIT_API_SECRET=
UPBIT_API_KEY=
UPBIT_API_SECRET=
BITHUMB_API_KEY=
BITHUMB_API_SECRET=
BINANCE_API_KEY=
BINANCE_API_SECRET=
# BINANCE_TESTNET=0                  # 1 = Binance testnet (separate keys)
# BINANCE_SPOT_FOCUS_ENABLED=false  # Binance spot engine on/off
# BINANCE_FUTURES_ENABLED=0         # Binance USDT-M futures engine on/off
# BINANCE_FUTURES_LIVE=0            # Binance futures live opt-in: 1 = real orders (only after testing); unset/0 = paper

# Single server (default). Multi-server "fleet" is ADVANCED/optional.
PEER_SERVER_URLS=
# PEER_BRIEF_TOKEN=
# CF_ACCESS_CLIENT_ID=
# CF_ACCESS_CLIENT_SECRET=
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
